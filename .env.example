# Copy to .env.local and fill in. .env.local is gitignored, never commit real keys.

# --- Model (chat + photo coaching, routed through OpenRouter) ---
OPENROUTER_API_KEY=
# Optional: pin a specific OpenRouter model slug. Defaults to
# anthropic/claude-sonnet-4.5. Browse slugs at https://openrouter.ai/models
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# --- Embeddings for RAG (OpenAI text-embedding-3-small) ---
OPENAI_API_KEY=

# --- Supabase ---
# URL + anon key are safe in the browser (RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key bypasses RLS. SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
