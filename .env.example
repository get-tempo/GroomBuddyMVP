# Copy to .env.local and fill in. .env.local is gitignored, never commit real keys.

# --- Model (chat + photo coaching, routed through OpenRouter) ---
OPENROUTER_API_KEY=
# Optional: pin a specific OpenRouter model slug. Defaults to
# anthropic/claude-sonnet-4.5. Browse slugs at https://openrouter.ai/models
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# --- Embeddings for RAG (OpenAI text-embedding-3-small) ---
OPENAI_API_KEY=

# --- Supabase ---
# URL + anon key are safe in the browser (RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key bypasses RLS. SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase keep-alive cron (optional, Vercel only) ---
# The free-tier project auto-pauses after ~7 days idle, silently killing RAG +
# analytics. A daily Vercel cron (vercel.json) pings the DB to keep it awake
# and auto-restores it if it paused anyway.
# Personal access token from supabase.com/dashboard/account/tokens. Needed only
# for the auto-restore path. SERVER ONLY.
SUPABASE_ACCESS_TOKEN=
# Random secret so only Vercel's cron scheduler can hit the endpoint. Vercel
# sends it automatically as a Bearer token when set.
CRON_SECRET=

# --- Pilot access gate (optional) ---
# Set to a shared class code to lock the app down for a student cohort: the app
# shows a code screen and /api/chat rejects calls without it (protects API $).
# Leave BLANK for an open app (local dev / public demo). Server-only, not public.
ACCESS_CODE=
